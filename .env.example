# =============================================================================
# Fathu Dives — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values. The app runs with
# typed mock data when these are absent, so you can develop the UI before
# connecting Supabase.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose in the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL used for SEO metadata and sitemaps.
NEXT_PUBLIC_SITE_URL=https://fathudives.com
